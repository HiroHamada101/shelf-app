{
  "expo": {
    "name": "Shelf",
    "slug": "shelf-app",
    "version": "1.0.0",
    "scheme": "shelf-app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9A602"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shelf.expirytracker"
    },
    "android": {
      "package": "com.shelf.expirytracker",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9A602"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Shelf to scan product labels and expiry dates.",
          "recordAudioAndroid": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "googleVisionApiKey": "AIzaSyCj9GjWsvyO711fsbedFRDPnJD_M-WRZS4",
      "firebaseApiKey": "",
      "firebaseAuthDomain": "",
      "firebaseProjectId": "",
      "firebaseStorageBucket": "",
      "firebaseMessagingSenderId": "",
      "firebaseAppId": "",
      "router": {},
      "eas": {
        "projectId": "6b988a6f-7960-40d1-899b-6abcf9229bb4"
      }
    }
  }
}
